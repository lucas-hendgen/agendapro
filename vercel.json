{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/admin/assets/(.*)",
      "dest": "/public/admin/assets/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/admin(?:/(.*))?",
      "dest": "/api/admin.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}